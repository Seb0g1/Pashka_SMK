{
  "expo": {
    "name": "СМК Техзаявки",
    "slug": "smk-tech-requests",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#f6f8fa"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "ru.smk.techrequests"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешите доступ к камере, чтобы сканировать QR-коды станков.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b4d1bdcd-cea0-45ff-b688-b0cf14732e35"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b4d1bdcd-cea0-45ff-b688-b0cf14732e35"
    }
  }
}
