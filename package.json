    "expo-font": "~14.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {}
}
